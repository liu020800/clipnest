<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>ClipNest.OcrHost</RootNamespace>
    <AssemblyName>wcocr</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="WeChatOcr" Version="1.0.3" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="$(NuGetPackageRoot)wechatocr\1.0.3\contentFiles\any\net8.0-windows7.0\wco_data\**\*">
      <Link>wco_data\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
